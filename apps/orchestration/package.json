{
  "name": "@locvm/orchestration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": "./src/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "node --env-file=../../.env src/index.js",
    "requeue": "node --env-file=../../.env scripts/requeue-all.js",
    "check-detail": "node --env-file=../../.env scripts/check-detail.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@locvm/communication": "*",
    "@locvm/database": "*",
    "@locvm/env": "*",
    "@locvm/matching-engine": "*",
    "@locvm/types": "*",
    "ejs": "^3.1.10"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
