{
  "name": "@locvm/matching-engine",
  "version": "0.1.0",
  "private": true,
  "description": "LOCVM matching engine — filter, score, rank",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "matching-harness": "scripts/matching-harness.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "analyze-data": "node scripts/analyzeTestData.js",
    "clean": "rimraf artificats ./*.tsbuildinfo",
    "clean:all": "rimraf node_modules harness_output ./*.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:harness": "node scripts/matching-harness.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@locvm/types": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "commander": "^13.0.0",
    "csv-stringify": "^6.5.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  }
}
