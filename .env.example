# MongoDB — same database as locvm-app
MONGODB_URI=mongodb://localhost:27017/locum

# HTTP port for the orchestration service
PORT=3001

# Shared secret with locvm-app for POST endpoint auth. Required in production.
MATCHING_SERVICE_SECRET=

# Token to access the dashboard UI. Required in production.
# Access via: http://localhost:3001/?token={DASHBOARD_TOKEN}
DASHBOARD_TOKEN=
